# Custom DLP rules
alert http any any -> any any (msg:"Potential Data Exfiltration - Large HTTP Upload"; flow:to_server; http.method; content:"POST"; http.uri; content:"upload"; depth:6; classtype:policy-violation; sid:1000001; rev:1;)
# Simplified DNS rule without unsupported keywords
alert dns any any -> any any (msg:"Potential DNS Tunneling - Long Domain"; dns.query; content:".com"; classtype:attempted-dos; sid:1000002; rev:1;)
